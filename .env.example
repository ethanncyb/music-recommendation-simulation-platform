# ── Local LLM (Ollama) ──────────────────────────────────────
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# ── EchoSphere-RAG (agentic pipeline, also uses Ollama) ────
ECHO_OLLAMA_MODEL=llama3.2
ECHO_OLLAMA_TEMPERATURE=0.4

# ── Online LLM Config ──────────────────────────────────────
# Which online provider to use: "anthropic" or "gemini"
ONLINE_LLM_PROVIDER=gemini

# ── Online LLM: Anthropic ──────────────────────────────────
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Online LLM: Gemini (free tier) ─────────────────────────
# Get a free key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key-here
